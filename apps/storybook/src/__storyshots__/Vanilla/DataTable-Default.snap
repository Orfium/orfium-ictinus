.emotion-0 {
  width: -webkit-fit-content;
  width: -moz-fit-content;
  width: fit-content;
}

.emotion-0 [data-disabled] {
  opacity: 50%;
  cursor: not-allowed;
}

.emotion-1 {
  display: block;
  cursor: pointer;
  position: relative;
}

.emotion-1 [data-role='checkbox-icon']>div {
  -webkit-transition: all 0.2s;
  transition: all 0.2s;
  width: var(--ictinus-sizing-5);
  height: var(--ictinus-sizing-5);
  -webkit-align-items: center;
  -webkit-box-align: center;
  -ms-flex-align: center;
  align-items: center;
  box-sizing: border-box;
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  border: var(--ictinus-border-width-2) solid var(--ictinus-color-border-color-interactive-default);
  border-radius: var(--ictinus-border-radius-2);
}

.emotion-1 svg {
  visibility: hidden;
  opacity: 0;
}

.emotion-1[data-hovered='true'] [data-role='checkbox-icon'],
.emotion-1[data-focus-visible='true'] [data-role='checkbox-icon'] {
  -webkit-transition: all 0.2s;
  transition: all 0.2s;
  background: rgba(200,206,255,0.20);
  box-shadow: 0px 0px 0px 8px rgba(200,206,255,0.20);
  border-radius: 100%;
}

.emotion-1[data-selected='true'] [data-role='checkbox-icon']>div,
.emotion-1[data-indeterminate='true'] [data-role='checkbox-icon']>div {
  -webkit-transition: all 0.2s;
  transition: all 0.2s;
  border-color: var(--ictinus-color-border-color-decorative-transparent);
  background: var(--ictinus-color-palette-primary-base);
}

.emotion-1[data-selected='true'] svg,
.emotion-1[data-indeterminate='true'] svg {
  visibility: visible;
  opacity: 1;
  -webkit-transition: all 0.2s;
  transition: all 0.2s;
}

.emotion-1[data-disabled='true'] {
  opacity: 50%;
  cursor: not-allowed;
}

.emotion-1[data-disabled='true']:hover {
  background: none;
  box-shadow: none;
}

.emotion-2 {
  -webkit-align-items: center;
  -webkit-box-align: center;
  -ms-flex-align: center;
  align-items: center;
  -webkit-flex-direction: row;
  -ms-flex-direction: row;
  flex-direction: row;
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  gap: 0.75rem;
  -webkit-box-pack: unset;
  -ms-flex-pack: unset;
  -webkit-justify-content: unset;
  justify-content: unset;
}

.emotion-6 {
  width: var(--ictinus-sizing-5);
  height: var(--ictinus-sizing-5);
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
}

.emotion-7 {
  width: var(--ictinus-sizing-5);
  height: var(--ictinus-sizing-5);
}

.emotion-7 path,
.emotion-7 rect {
  fill: var(--ictinus-color-text-inverted-primary)!important;
}

