    "dayjs": "2.0.0-alpha.4",
    "lodash-es": "^4.18.1",
    "polished": "^4.3.1",
    "react-docgen-typescript": "^2.4.0",
    "react-router": "^7.16.0",
    "react-stately": "^3.47.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@emotion/jest": "^11.14.2",
