{
  "name": "design-system",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "license": "MIT",
  "keywords": [
    "Orfium",
    "typescript",
    "react",
    "styled-system",
    "emotion",
    "design system"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "turbo dev",
    "build": "turbo build",
    "tsc": "turbo tsc",
    "lint": "turbo lint",
    "test": "turbo test",
    "check": "turbo check",
    "precommit": "turbo run precommit --affected",
    "coverage:report": "turbo build --filter='./packages/*' && vitest run --coverage",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "release:experimental": "turbo run build --filter='./packages/*' && changeset publish --tag experimental"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Orfium/orfium-ictinus.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "husky": "^9.1.7",
    "oxlint": "^1.67.0",
    "prettier": "^3.8.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "turbo": "^2.9.14",
    "typescript": "^5.9.2",
    "vitest": "catalog:"
  },
  "bugs": {
    "url": "https://github.com/Orfium/orfium-ictinus/issues"
  },
  "homepage": "https://github.com/Orfium/orfium-ictinus#readme",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  }
}
