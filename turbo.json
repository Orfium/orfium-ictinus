{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "check": {},
    "precommit": {
      "dependsOn": ["^build"]
    },
    "fmt": {},
    "tsc": {},
    "lint": {},
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
